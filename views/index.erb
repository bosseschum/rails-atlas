<!DOCTYPE html>
<html>
<head>
  <title>Rails Atlas</title>

  <script
    type="text/javascript"
    src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js">
  </script>

  <style>
    body {
      font-family: sans-serif;
      margin: 0;
      overflow: hidden;
    }

    #network {
      width: calc(100vw - 300px);
      height: 100vh;
    }

    #sidebar {
      position: fixed;
      top: 0;
      right: 0;

      width: 300px;
      height: 100vh;

      background-color: white;
      border-left: 1px solid #ddd;

      box-sizing: border-box;
    }

    #sidebar-content {
      height: 100%;
      overflow-y: auto;
      padding: 1rem;
    }

    #drag-handle {
      position: absolute;
      top: 50%;
      left: -3px;
      transform: translateY(-50%);
      width: 6px;
      height: 50px;
      background-color: #ccc;
      cursor: col-resize;
      border-radius: 10px;
      z-index: 10;
    }

    #search {
      position: fixed;
      top: 10px;
      left: 10px;

      z-index: 1000;

      padding: 8px;
      width: 250px;
    }
  </style>
</head>

<body>
  <input type="text" id="search" placeholder="Find model..."/>
  <div id="network"></div>

  <div id="sidebar">
    <div id="drag-handle"></div>
    <div id="sidebar-content">
      <h2>Rails Atlas</h2>
      Click on a model node to see its details
    </div>
  </div>

  <script>
    fetch('/api/graph')
      .then(response => response.json())
      .then(data => {

        const nodes = new vis.DataSet(
          data.nodes.map(node => ({
            id: node.id,
            label: node.id,
            degree: node.degree,

            color:
                node.degree >= 10 ? '#ef4444' :
                node.degree >= 5 ? '#f59e0b' :
                '#3b82f6'
          }))
        )

        const edges = new vis.DataSet(
          data.edges.map(edge => ({
            from: edge.source,
            to: edge.target,
            arrows: 'to'
          }))
        )

        const network = new vis.Network(
          document.getElementById('network'),
          { nodes, edges },
          {
            physics: true
          }
        )

        document
          .getElementById('search')
          .addEventListener('input', event => {
            const query = event.target.value.toLowerCase()

            nodes.forEach(node => {
              nodes.update({
                id: node.id,
                hidden:
                    query.length > 0 &&
                    !node.label.toLowerCase().includes(query)
              })
            })

          })

        network.on('click', function(params) {
          if (params.nodes.length === 0) return

          const model = params.nodes[0]

          console.log('clicked', model)

          loadModel(model)
        })

        function loadModel(model) {
          Promise.all([
            fetch(`/api/models/${model}`).then(r => r.json()),
            fetch(`/api/impact/${model}`).then(r => r.json())
          ])
            .then(([connections, impact]) => {
              renderSidebar(model, connections, impact)
              highlightImpact(model, impact)
            })
        }

        function renderSidebar(model, connections, impact) {
          const sidebarContent = document.getElementById('sidebar-content')

          sidebarContent.innerHTML = `
            <h2>${model}</h2>

            <h3>Connections</h3>
            <ul>
              ${connections.map(connection => `
              <li>
              ${
              connection.direction === 'outgoing' ? '→' : '←'
              }
              ${connection.relationship}
              ${connection.model}
              </li>
              `).join('')}
            </ul>

            <h3>Impact</h3>
            <p>${impact.length} reachable models</p>

            <ul>
              ${impact.map(model => `
              <li>${model}</li>
              `).join('')}
            </ul>
          `
        }

        function highlightImpact(selectedModel, impactModels) {
          const impacted = new Set([
            selectedModel,
            ...impactModels
          ])

          nodes.forEach(node => {
            nodes.update({
              id: node.id,
              opacity: impacted.has(node.id) ? 1 : 0.2
            })
          })
        }

        function resetHighlight() {
          nodes.forEach(node => {
            nodes.update({
              id: node.id,
              opacity: 1
            })
          })

          document.getElementById('sidebar-content').innerHTML = `
          <h2>Rails Atlas</h2>
          <p>Click on a model to see its details</p>
          `
        }

      })

      const sidebar = document.getElementById('sidebar')
      const dragHandle = document.querySelector('#drag-handle')

      dragHandle.addEventListener('mousedown', (e) => {
        document.addEventListener('mousemove', resizeSidebar);
        document.addEventListener('mouseup', stopResize);
      });

      function resizeSidebar(e) {
        const newWidth = window.innerWidth - e.clientX;
        if (newWidth > 200 && newWidth < 600) {
          sidebar.style.width = `${newWidth}px`;

          document.getElementById('network').style.width = `calc(100vw - ${newWidth}px)`;
          network.redraw()
          network.fit({
            animation: false
          })
        }
      }

      function stopResize() {
        document.removeEventListener('mousemove', resizeSidebar);
        document.removeEventListener('mouseup', stopResize);
      }

  </script>
</body>
</html>
